<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_payment_line_wizard_form" model="ir.ui.view">
        <field name="name">import.payment.line.wizard.form</field>
        <field name="model">import.payment.line.wizard</field>
        <field name="arch" type="xml">
            <form string="Agregar Compromiso de Pago">
                <group col="2">
                    <group string="Datos del Compromiso">
                        <field name="report_id" readonly="1"/>
                        <field name="commitment_category" widget="radio"/>
                        <field name="partner_id"/>
                        <field name="name" placeholder="Descripción del compromiso..."/>
                        <field name="invoice_reference" placeholder="No. factura proveedor"/>
                    </group>
                    <group string="Montos y Fechas">
                        <field name="amount_original"/>
                        <field name="currency_id"/>
                        <field name="due_date"/>
                        <field name="eta_date"/>
                        <field name="payment_programmed_date"/>
                        <field name="payment_term_type" placeholder="Ej: 120 días"/>
                    </group>
                </group>
                <group col="2" invisible="commitment_category != 'import_tax'">
                    <group string="Impuestos">
                        <field name="tax_amount_mxn"/>
                        <field name="tax_is_estimate"/>
                    </group>
                </group>
                <group col="2">
                    <group string="Referencias">
                        <field name="purchase_order_id"/>
                        <field name="bl_number"/>
                        <field name="container_numbers"/>
                        <field name="sales_orders"/>
                    </group>
                    <group string="Notas">
                        <field name="note" nolabel="1"/>
                    </group>
                </group>
                <footer>
                    <button string="Agregar" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
