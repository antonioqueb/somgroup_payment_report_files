<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ CLIENT ACTION — Dashboard JS de Ana ═════════════════════════ -->
    <record id="action_import_payment_dashboard" model="ir.actions.client">
        <field name="name">📊 Visor de Pagos</field>
        <field name="tag">import_payment_dashboard</field>
    </record>

    <!-- ═══ MENÚS ═══════════════════════════════════════════════════════ -->
    <menuitem id="menu_import_payments_root"
              name="📊 Pagos Importaciones"
              parent="purchase.menu_purchase_root"
              sequence="20"/>

    <!-- Dashboard (vista principal de Ana) -->
    <menuitem id="menu_import_payment_dashboard"
              name="Visor de Pagos"
              parent="menu_import_payments_root"
              action="action_import_payment_dashboard"
              sequence="5"/>

    <!-- Reportes mensuales -->
    <menuitem id="menu_import_payment_report"
              name="Reportes Mensuales"
              parent="menu_import_payments_root"
              action="action_import_payment_report"
              sequence="10"/>

    <!-- Todos los compromisos -->
    <menuitem id="menu_import_payment_lines"
              name="Todos los Compromisos"
              parent="menu_import_payments_root"
              action="action_import_payment_line_all"
              sequence="20"/>

    <!-- Proyección futura -->
    <menuitem id="menu_import_payment_projection"
              name="Proyección Meses Futuros"
              parent="menu_import_payments_root"
              action="action_import_payment_line_projection"
              sequence="30"/>

</odoo>
