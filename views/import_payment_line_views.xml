<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── FORM ─────────────────────────────────────────────────────── -->
    <record id="view_import_payment_line_form" model="ir.ui.view">
        <field name="name">import.payment.line.form</field>
        <field name="model">import.payment.line</field>
        <field name="arch" type="xml">
            <form string="Compromiso de Pago">
                <header>
                    <button name="action_register_payment"
                            string="💵 Registrar Pago" type="object"
                            class="btn-primary" invisible="state == 'paid'"/>
                    <button name="action_mark_paid"
                            string="✓ Marcar Pagado" type="object"
                            class="btn-secondary" invisible="state == 'paid'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,partial,paid"/>
                </header>
                <sheet>
                    <div class="oe_title mb-3">
                        <h1><field name="name"/></h1>
                    </div>
                    <group col="2">
                        <group string="Identificación">
                            <field name="commitment_category" widget="radio"/>
                            <field name="partner_id"/>
                            <field name="invoice_reference"/>
                            <field name="purchase_order_id"/>
                            <field name="account_move_id"/>
                            <field name="report_id"/>
                        </group>
                        <group string="Montos">
                            <field name="amount_original"/>
                            <field name="currency_id"/>
                            <field name="amount_usd" readonly="1"/>
                            <field name="amount_mxn" readonly="1"/>
                            <field name="paid_amount"/>
                            <field name="remaining_amount" readonly="1"/>
                            <field name="currency_usd_id" invisible="1"/>
                            <field name="currency_mxn_id" invisible="1"/>
                        </group>
                    </group>
                    <group col="2">
                        <group string="Fechas">
                            <field name="due_date"/>
                            <field name="eta_date"/>
                            <field name="payment_programmed_date"/>
                            <field name="paid_date"/>
                            <field name="days_until_due" readonly="1"/>
                            <field name="alert_level" readonly="1"/>
                        </group>
                        <group string="Referencias">
                            <field name="bl_number"/>
                            <field name="container_numbers"/>
                            <field name="sales_orders"/>
                            <field name="payment_term_type"/>
                            <field name="target_month_display" readonly="1"/>
                        </group>
                    </group>
                    <group col="2" invisible="commitment_category != 'import_tax'">
                        <group string="Impuestos de Importación">
                            <field name="tax_amount_mxn"/>
                            <field name="tax_is_estimate"/>
                        </group>
                    </group>
                    <separator string="Notas"/>
                    <field name="note" nolabel="1"/>
                    <separator string="Pagos Contables" invisible="not payment_ids"/>
                    <field name="payment_ids" readonly="1" invisible="not payment_ids">
                        <list>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── LIST ──────────────────────────────────────────────────────── -->
    <record id="view_import_payment_line_list" model="ir.ui.view">
        <field name="name">import.payment.line.list</field>
        <field name="model">import.payment.line</field>
        <field name="arch" type="xml">
            <list string="Compromisos de Pago"
                  decoration-danger="state == 'overdue'"
                  decoration-success="state == 'paid'"
                  decoration-warning="alert_level == 'warning'">
                <field name="target_month_display" string="Mes"/>
                <field name="commitment_category" string="Categoría"/>
                <field name="partner_id" string="Proveedor"/>
                <field name="invoice_reference" string="Factura"/>
                <field name="amount_original" string="Monto"/>
                <field name="currency_id" string="Mon."/>
                <field name="amount_usd" string="USD" optional="hide"/>
                <field name="amount_mxn" string="MXN" optional="hide"/>
                <field name="due_date" string="Vencimiento"/>
                <field name="days_until_due" string="Días" readonly="1"/>
                <field name="state" widget="badge" string="Estado"
                       decoration-success="state == 'paid'"
                       decoration-danger="state == 'overdue'"
                       decoration-warning="state == 'pending'"
                       decoration-info="state == 'partial'"/>
                <field name="payment_term_type" string="Término" optional="hide"/>
                <field name="eta_date" string="ETA" optional="hide"/>
                <field name="alert_level" column_invisible="1"/>
                <field name="currency_usd_id" column_invisible="1"/>
                <field name="currency_mxn_id" column_invisible="1"/>
                <button name="action_register_payment" string="💵" type="object"
                        class="btn btn-sm btn-success" invisible="state == 'paid'"/>
            </list>
        </field>
    </record>

    <!-- ── SEARCH ───────────────────────────────────────────────────── -->
    <record id="view_import_payment_line_search" model="ir.ui.view">
        <field name="name">import.payment.line.search</field>
        <field name="model">import.payment.line</field>
        <field name="arch" type="xml">
            <search string="Buscar Compromisos">
                <field name="partner_id"/>
                <field name="name"/>
                <field name="invoice_reference"/>
                <field name="purchase_order_id"/>
                <filter string="Pendientes" name="pending"
                        domain="[('state','in',['pending','partial'])]"/>
                <filter string="Vencidos" name="overdue"
                        domain="[('state','=','overdue')]"/>
                <filter string="Pagados" name="paid"
                        domain="[('state','=','paid')]"/>
                <separator/>
                <filter string="Crédito Import." name="cat_credit"
                        domain="[('commitment_category','=','credit_import')]"/>
                <filter string="Fletes Marítimos" name="cat_sea"
                        domain="[('commitment_category','=','credit_freight_sea')]"/>
                <filter string="Fletes Terrestres" name="cat_land"
                        domain="[('commitment_category','=','credit_freight_land')]"/>
                <filter string="Anticipos" name="cat_advance"
                        domain="[('commitment_category','=','advance')]"/>
                <filter string="Balances" name="cat_balance"
                        domain="[('commitment_category','=','balance')]"/>
                <filter string="Impuestos" name="cat_tax"
                        domain="[('commitment_category','=','import_tax')]"/>
                <separator/>
                <filter string="Por Categoría" name="group_category"
                        context="{'group_by': 'commitment_category'}"/>
                <filter string="Por Mes" name="group_month"
                        context="{'group_by': 'target_month'}"/>
                <filter string="Por Proveedor" name="group_partner"
                        context="{'group_by': 'partner_id'}"/>
                <filter string="Por Estado" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- ── PIVOT ────────────────────────────────────────────────────── -->
    <record id="view_import_payment_line_pivot" model="ir.ui.view">
        <field name="name">import.payment.line.pivot</field>
        <field name="model">import.payment.line</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Pagos">
                <field name="target_month" type="row"/>
                <field name="commitment_category" type="col"/>
                <field name="amount_mxn" type="measure"/>
                <field name="amount_usd" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ── GRAPH ────────────────────────────────────────────────────── -->
    <record id="view_import_payment_line_graph" model="ir.ui.view">
        <field name="name">import.payment.line.graph</field>
        <field name="model">import.payment.line</field>
        <field name="arch" type="xml">
            <graph string="Gráfico de Pagos" type="bar" stacked="1">
                <field name="target_month"/>
                <field name="amount_mxn" type="measure"/>
                <field name="commitment_category" type="col"/>
            </graph>
        </field>
    </record>

    <!-- ── Acciones ─────────────────────────────────────────────────── -->
    <record id="action_import_payment_line_all" model="ir.actions.act_window">
        <field name="name">Todos los Compromisos</field>
        <field name="res_model">import.payment.line</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <record id="action_import_payment_line_projection" model="ir.actions.act_window">
        <field name="name">Proyección Meses Futuros</field>
        <field name="res_model">import.payment.line</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="context">{'search_default_group_month': 1}</field>
    </record>

</odoo>
